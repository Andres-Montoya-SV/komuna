DATABASE_URL=postgresql://exposure:exposure@localhost:5432/exposure

ENV=development
LOG_LEVEL=INFO

# Firebase Admin credential JSON path (recommended for local dev). Leave empty only if ADC is configured.
FIREBASE_CREDENTIALS_PATH=

# Optional hardening for multi-project setups: Firebase OAuth client IDs/GCP OAuth client IDs, comma-separated.
FIREBASE_ALLOWED_AUDIENCES=

SCAN_POLL_INTERVAL_SECONDS=30

# Disable if you prefer manual/on-demand scans only.
SCHEDULED_SCAN_ENABLED=true
SCHEDULED_SCAN_INTERVAL_HOURS=24

CRT_SH_TIMEOUT_SECONDS=30
HTTP_TIMEOUT_SECONDS=15
DNS_TIMEOUT_SECONDS=10
