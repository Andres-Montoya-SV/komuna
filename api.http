@baseUrl = http://localhost:2077/api/v1
@authToken = {{login.response.body.token}}

### Health Check
GET http://localhost:2077/health

### Database Ready Check
GET http://localhost:2077/ready

###
# @name login
POST {{baseUrl}}/users/login
Content-Type: application/json

{
    "email": "test@example.com",
    "password": "password123"
}

### Register User
POST {{baseUrl}}/users/register
Content-Type: application/json

{
    "email": "newuser@example.com",
    "password": "password123",
    "first_name": "John",
    "last_name": "Doe",
    "username": "johndoe"
}

### Get User Profile
GET {{baseUrl}}/users/userID_placeholder
Authorization: Bearer {{authToken}}

### Update User Profile
PUT {{baseUrl}}/users/userID_placeholder
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
    "first_name": "Jonathan",
    "bio": "Updated bio"
}

### List Communities
GET {{baseUrl}}/communities
Authorization: Bearer {{authToken}}

### Create Community
POST {{baseUrl}}/communities
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
    "name": "Developers",
    "description": "A community for devs"
}

### Get Community
GET {{baseUrl}}/communities/communityID_placeholder
Authorization: Bearer {{authToken}}

### List Products
GET {{baseUrl}}/store/products?community_id=communityID_placeholder
Authorization: Bearer {{authToken}}

### Create Product
POST {{baseUrl}}/store/products
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
    "name": "Mechanical Keyboard",
    "description": "Clicky keys",
    "price": 150.00,
    "community_id": "communityID_placeholder"
}
